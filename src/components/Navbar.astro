---
import menu from '../../menu.json';

const { business } = menu;

interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;
---

<header class="navbar">
  <div class="navbar-container">
    <div class="navbar-brand">
      <a href="/" class="brand-link">
        <img src="/PepoPizza/assets/images/logo.webp" alt="{business.name}" class="brand-logo" />
      </a>
      <nav class="navbar-nav desktop-only">
        <a href="/" class={`nav-link ${currentPage === 'home' ? 'active' : ''}`}>Inicio</a>
        <a href="/menu" class={`nav-link ${currentPage === 'menu' ? 'active' : ''}`}>Menú</a>
        <a href="/instrucciones" class={`nav-link ${currentPage === 'instrucciones' ? 'active' : ''}`}>Instrucciones</a>
      </nav>
    </div>
    <div class="navbar-actions">
      <button class="hamburger-button" id="hamburger-toggle" aria-label="Abrir menú">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-header">
    <span class="brand-name">{business.name}</span>
    <button class="mobile-menu-close" id="mobile-menu-close" aria-label="Cerrar menú">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>
  <nav class="mobile-nav">
    <a href="/" class={`mobile-nav-link ${currentPage === 'home' ? 'active' : ''}`}>
      <span class="material-symbols-outlined">home</span>
      Inicio
    </a>
    <a href="/menu" class={`mobile-nav-link ${currentPage === 'menu' ? 'active' : ''}`}>
      <span class="material-symbols-outlined">restaurant_menu</span>
      Menú
    </a>
    <a href="/instrucciones" class={`mobile-nav-link ${currentPage === 'instrucciones' ? 'active' : ''}`}>
      <span class="material-symbols-outlined">info</span>
      Instrucciones
    </a>
  </nav>
</div>

<!-- Mobile Menu Backdrop -->
<div class="mobile-menu-backdrop" id="mobile-menu-backdrop"></div>

<script>
  const hamburgerBtn = document.getElementById('hamburger-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');

  function openMobileMenu() {
    mobileMenu?.classList.add('open');
    mobileMenuBackdrop?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    mobileMenu?.classList.remove('open');
    mobileMenuBackdrop?.classList.remove('open');
    document.body.style.overflow = '';
  }

  hamburgerBtn?.addEventListener('click', openMobileMenu);
  mobileMenuClose?.addEventListener('click', closeMobileMenu);
  mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-surface);
    box-shadow: 0 1px 3px rgba(49, 47, 38, 0.05);
  }

  .navbar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .brand-logo {
    height: 3rem;
    width: auto;
  }

  .brand-name {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 900;
    font-style: italic;
    color: var(--color-primary);
  }

  .navbar-nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1.125rem;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    color: var(--color-on-surface-variant);
    padding-bottom: 0.25rem;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-on-surface);
  }

  .nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cart-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: var(--color-primary);
    cursor: pointer;
    transition: opacity 0.2s ease;
    border-radius: 50%;
  }

  .cart-button:hover {
    opacity: 0.8;
  }

  .cart-button:active {
    transform: scale(0.95);
  }

  .cart-button .material-symbols-outlined {
    font-size: 1.5rem;
  }

  .hamburger-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: var(--color-on-surface);
    cursor: pointer;
    transition: opacity 0.2s ease;
    border-radius: 50%;
  }

  .hamburger-button:hover {
    opacity: 0.8;
  }

  .hamburger-button:active {
    transform: scale(0.95);
  }

  .hamburger-button .material-symbols-outlined {
    font-size: 1.75rem;
  }

  .desktop-only {
    display: none;
  }

  @media (min-width: 768px) {
    .desktop-only {
      display: flex;
    }

    .hamburger-button {
      display: none;
    }
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    max-width: 80vw;
    height: 100%;
    background-color: var(--color-surface);
    box-shadow: var(--shadow-xl);
    z-index: 60;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .mobile-menu-close {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: var(--color-on-surface-variant);
    cursor: pointer;
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }

  .mobile-menu-close:hover {
    background-color: var(--color-surface-container-low);
  }

  .mobile-menu-close .material-symbols-outlined {
    font-size: 1.5rem;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.5rem;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-xl);
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-on-surface-variant);
    transition: all 0.2s ease;
  }

  .mobile-nav-link:hover {
    background-color: var(--color-surface-container-low);
    color: var(--color-on-surface);
  }

  .mobile-nav-link.active {
    background-color: var(--color-primary-container);
    color: var(--color-on-primary-container);
  }

  .mobile-nav-link .material-symbols-outlined {
    font-size: 1.5rem;
  }

  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 55;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .mobile-menu-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 768px) {
    .mobile-menu,
    .mobile-menu-backdrop {
      display: none;
    }
  }
</style>
