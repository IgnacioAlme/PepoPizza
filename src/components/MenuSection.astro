---
import menu from '../../menu.json';

const { categories, variants } = menu;

// Calculate variant price: 55% of base price, rounded UP to nearest hundred
function calculateVariantPrice(basePrice: number, multiplier: number): number {
  const price = basePrice * multiplier;
  return Math.ceil(price / 100) * 100;
}
---

<section class="menu-section section" id="menu">
  <div class="container">
    <div class="menu-header">
      <div class="menu-title">
        <h2>Nuestras Variedades</h2>
        <p>Elegí tu favorita y la cantidad de porciones.</p>
      </div>
      <div class="menu-actions">
        <a href="/PepoPizza/instrucciones" class="btn-instructions">
          <span class="material-symbols-outlined">help</span>
          Cómo prepararla
        </a>
        <span class="tag">Artesanales</span>
      </div>
    </div>

    {categories.map((category) => (
      <div class="menu-category">
        <h3 class="category-title">{category.label}</h3>
        <div class="menu-grid">
          {category.items.map((pizza) => (
            <div class="product-card">
              <div class="product-image">
                <div class="image-placeholder-product">
                  <span class="material-symbols-outlined">local_pizza</span>
                </div>
                {pizza.badge && (
                  <span class="product-badge">{pizza.badge}</span>
                )}
              </div>
              <div class="product-content">
                <h3 class="product-name">{pizza.name}</h3>
                
                {pizza.ingredients && (
                  <div class="product-ingredients">
                    {pizza.ingredients.join(', ')}
                  </div>
                )}
                
                <!-- Variant Buttons -->
                <div class="variant-buttons">
                  {variants.map((variant) => (
                    <button 
                      class="btn-add-variant" 
                      data-id={pizza.id}
                      data-name={pizza.name}
                      data-price={calculateVariantPrice(pizza.price, variant.priceMultiplier)}
                      data-variant={variant.id}
                      data-variant-label={String(variant.portions)}
                    >
                      <span class="variant-label"><strong>{variant.portions}</strong><span class="material-symbols-outlined variant-icon">local_pizza</span></span>
                      <span class="variant-price">${calculateVariantPrice(pizza.price, variant.priceMultiplier).toLocaleString('es-AR')}</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .menu-section {
    background-color: var(--color-surface-container-low);
  }

  .menu-header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .menu-title h2 {
    margin-bottom: 0.5rem;
  }

  .menu-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .btn-instructions {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    background-color: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-instructions:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .btn-instructions .material-symbols-outlined {
    font-size: 1.25rem;
  }

  .tag {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    background-color: var(--color-surface-container-highest);
    color: var(--color-on-surface-variant);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .menu-category {
    margin-bottom: 3rem;
  }

  .category-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .menu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .product-card {
    background-color: var(--color-surface-container-lowest);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(49, 47, 38, 0.05);
    transition: box-shadow 0.3s ease;
  }

  .product-card:hover {
    box-shadow: 0 4px 12px rgba(49, 47, 38, 0.1);
  }

  .product-image {
    position: relative;
    height: 16rem;
    overflow: hidden;
  }

  .image-placeholder-product {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface-container-high) 0%, var(--color-surface-dim) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder-product .material-symbols-outlined {
    font-size: 5rem;
    color: var(--color-on-surface-variant);
    transition: transform 0.5s ease;
  }

  .product-card:hover .image-placeholder-product .material-symbols-outlined {
    transform: scale(1.1);
  }

  .product-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-name {
    font-size: 1.5rem;
  }

  .product-ingredients {
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
    line-height: 1.4;
  }

  /* Variant Buttons */
  .variant-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .btn-add-variant {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-surface-container-highest);
    color: var(--color-on-surface);
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-add-variant:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .btn-add-variant .variant-label {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .btn-add-variant .variant-icon {
    font-size: 1.1em;
    line-height: 1;
  }

  .btn-add-variant .variant-price {
    font-weight: 900;
  }

  @media (min-width: 480px) {
    .variant-buttons {
      flex-direction: row;
    }

    .btn-add-variant {
      flex: 1;
      padding: 0.875rem 1rem;
      font-size: 0.8125rem;
    }
  }

  @media (min-width: 768px) {
    .menu-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  @media (min-width: 1024px) {
    .menu-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>