---
import menu from '../../menu.json';

const { business } = menu;
---

<section class="owner section" id="historia">
  <div class="container">
    <div class="owner-grid">
      <div class="owner-image-wrapper">
        <div class="owner-image">
          <img 
            src="/PepoPizza/assets/images/chef.jpg" 
            alt="Sergio, dueño de Pepo Pizza" 
            class="owner-img"
          />
        </div>
        <div class="owner-badge">
          Artesanal y Casero
        </div>
      </div>
      
      <div class="owner-content">
        <span class="owner-label">
          <span class="label-line"></span>
          Conoce al Pizzero
        </span>
        <h2>
          Detrás de cada <span class="text-highlight">{business.name}</span>
        </h2>
        <div class="owner-story">
          <p>{business.owner?.story}</p>
          <p class="owner-cta">Si querés probar, escribime por mensaje directo</p>
        </div>
        <a href={`https://wa.me/${business.whatsapp}`} class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
          <svg class="whatsapp-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.067 2.877 1.215 3.076.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path>
          </svg>
          Escribime por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .owner {
    background-color: var(--color-surface);
    overflow: hidden;
  }

  .owner-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .owner-image-wrapper {
    position: relative;
    display: none;
  }

  .owner-image {
    position: relative;
    z-index: 10;
  }

  .owner-image::before {
    content: '';
    position: absolute;
    top: -1rem;
    left: -1rem;
    right: 1rem;
    bottom: 1rem;
    border: 2px solid rgba(181, 26, 10, 0.2);
    border-radius: var(--radius-xl);
  }

  .owner-img {
    width: 100%;
    height: 600px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
  }

  .owner-badge {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    z-index: 20;
    background-color: var(--color-secondary);
    color: var(--color-on-secondary);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--font-headline);
    font-weight: 700;
    font-style: italic;
    box-shadow: var(--shadow-lg);
    transform: rotate(3deg);
  }

  .owner-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .owner-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-secondary);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .label-line {
    width: 3rem;
    height: 2px;
    background-color: var(--color-secondary);
  }

  .owner-content h2 {
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .text-highlight {
    color: var(--color-primary);
    font-style: italic;
  }

  .owner-story {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .owner-story p {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-on-surface-variant);
  }

  .owner-cta {
    font-weight: 500;
    color: var(--color-on-surface) !important;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background-color: #25D366;
    color: white;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transition: all 0.2s ease;
    width: fit-content;
    margin-top: 1rem;
  }

  .btn-whatsapp:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-xl);
    background-color: #1da851;
  }

  .whatsapp-icon {
    width: 1.5rem;
    height: 1.5rem;
    fill: currentColor;
  }

  @media (min-width: 768px) {
    .owner-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .owner-image-wrapper {
      display: block;
    }
  }
</style>
