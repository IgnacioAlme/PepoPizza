---
import menu from '../../menu.json';

const { convenience } = menu;
---

<section class="convenience section">
  <div class="container">
    <div class="convenience-grid">
      <div class="convenience-steps">
        <div class="steps-grid">
          {convenience.map((step, index) => (
            <div class={`step-card ${index % 2 === 0 ? 'offset' : ''}`}>
              <div class="step-icon-wrapper">
                <span class="material-symbols-outlined step-icon">{step.icon}</span>
              </div>
              <h4 class="step-title">{step.title}</h4>
              <p class="step-description">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
      
      <div class="convenience-content">
        <h2>
          Del Freezer al <span class="text-highlight">Corazón</span>
        </h2>
        <p class="convenience-intro">
          En Pepo Pizza reinventamos el concepto de comida congelada. Usamos un proceso de ultracongelación que mantiene la estructura del gluten y la frescura de los ingredientes intacta.
        </p>
        <ul class="convenience-list">
          <li>
            <span class="material-symbols-outlined check-icon">check_circle</span>
            Sin conservantes artificiales
          </li>
          <li>
            <span class="material-symbols-outlined check-icon">check_circle</span>
            Masa con 48hs de fermentación
          </li>
          <li>
            <span class="material-symbols-outlined check-icon">check_circle</span>
            Salsa de tomates italianos
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .convenience {
    background-color: var(--color-surface);
    overflow: hidden;
  }

  .convenience-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .step-card {
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .step-card {
      padding: 2rem;
    }
  }

  .step-card:nth-child(1) {
    background-color: rgba(161, 209, 254, 0.3);
  }

  .step-card:nth-child(2) {
    background-color: rgba(255, 119, 97, 0.2);
  }

  .step-card:nth-child(3) {
    background-color: rgba(255, 198, 154, 0.3);
  }

  .step-card:nth-child(4) {
    background-color: var(--color-surface-container-high);
  }

  .step-icon-wrapper {
    margin-bottom: 0.5rem;
  }

  .step-icon {
    font-size: 3rem;
  }

  .step-card:nth-child(1) .step-icon {
    color: var(--color-tertiary);
  }

  .step-card:nth-child(2) .step-icon {
    color: var(--color-primary);
  }

  .step-card:nth-child(3) .step-icon {
    color: var(--color-secondary);
  }

  .step-card:nth-child(4) .step-icon {
    color: var(--color-on-surface-variant);
  }

  .step-title {
    font-size: 1rem;
    font-weight: 700;
  }

  .step-description {
    font-size: 0.75rem;
  }

  .convenience-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .convenience-content h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
  }

  .text-highlight {
    color: var(--color-primary);
    font-style: italic;
  }

  .convenience-intro {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-on-surface-variant);
  }

  .convenience-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .convenience-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-weight: 500;
    color: var(--color-on-surface);
  }

  .check-icon {
    color: var(--color-primary);
    font-size: 1.5rem;
  }

  @media (min-width: 768px) {
    .convenience-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .convenience-steps {
      order: 2;
    }
  }
</style>
