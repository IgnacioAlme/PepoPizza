---
import menu from '../../menu.json';

const { business } = menu;
---

<!-- Floating Cart Button -->
<button class="cart-floating" id="cart-floating" aria-label="Ver carrito">
  <span class="material-symbols-outlined">shopping_basket</span>
  <span class="cart-count" id="cart-count">0</span>
</button>

<!-- Cart Sidebar -->
<aside class="cart-sidebar" id="cart-sidebar">
  <div class="cart-header">
    <h3>Tu Carrito</h3>
    <button class="cart-close" id="cart-close" aria-label="Cerrar carrito">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>
  
  <div class="cart-items" id="cart-items">
    <!-- Cart items will be injected here via JavaScript -->
    <div class="cart-empty" id="cart-empty">
      <span class="material-symbols-outlined">shopping_cart</span>
      <p>Tu carrito está vacío</p>
    </div>
  </div>
  
  <div class="cart-footer">
    <div class="cart-total">
      <span>Total</span>
      <span class="total-amount" id="cart-total">$0</span>
    </div>
    <button class="btn-checkout" id="btn-checkout" disabled>
      Confirmar Pedido
    </button>
  </div>
</aside>

<!-- Cart Backdrop -->
<div class="cart-backdrop" id="cart-backdrop"></div>

<script define:vars={{ business }}>
  // Cart State
  let cart = [];
  
  // DOM Elements
  const cartFloating = document.getElementById('cart-floating');
  const cartSidebar = document.getElementById('cart-sidebar');
  const cartClose = document.getElementById('cart-close');
  const cartBackdrop = document.getElementById('cart-backdrop');
  const cartItems = document.getElementById('cart-items');
  const cartEmpty = document.getElementById('cart-empty');
  const cartCount = document.getElementById('cart-count');
  const cartTotal = document.getElementById('cart-total');
  const btnCheckout = document.getElementById('btn-checkout');
  
  // Add to Cart functions
  window.addToCart = function(id, name, price, variant = '8-porciones', variantLabel = '8 Porciones') {
    // Use id + variant as unique key
    const itemKey = `${id}-${variant}`;
    const existingItem = cart.find(item => item.itemKey === itemKey);
    
    if (existingItem) {
      existingItem.quantity++;
    } else {
      cart.push({ id, name, price, variant, variantLabel, quantity: 1, itemKey });
    }
    
    updateCartUI();
  };
  
  // Remove from Cart
  window.removeFromCart = function(itemKey) {
    const index = cart.findIndex(item => item.itemKey === itemKey);
    if (index > -1) {
      if (cart[index].quantity > 1) {
        cart[index].quantity--;
      } else {
        cart.splice(index, 1);
      }
    }
    updateCartUI();
  };
  
  // Update Cart UI
  function updateCartUI() {
    // Update count badge
    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
    cartCount.textContent = totalItems;
    cartCount.style.display = totalItems > 0 ? 'flex' : 'none';
    
    // Update items list
    if (cart.length === 0) {
      cartEmpty.style.display = 'flex';
      // Remove all items except empty message
      const items = cartItems.querySelectorAll('.cart-item');
      items.forEach(item => item.remove());
    } else {
      cartEmpty.style.display = 'none';
      
      // Clear and rebuild items
      const items = cartItems.querySelectorAll('.cart-item');
      items.forEach(item => item.remove());
      
      cart.forEach(item => {
        const itemEl = document.createElement('div');
        itemEl.className = 'cart-item';
        itemEl.innerHTML = `
          <div class="cart-item-image">
            <span class="material-symbols-outlined">local_pizza</span>
          </div>
          <div class="cart-item-info">
            <p class="cart-item-name">${item.name}</p>
            <p class="cart-item-variant">${item.variantLabel}</p>
            <p class="cart-item-price">${item.quantity} x $${item.price.toLocaleString('es-AR')}</p>
          </div>
          <button class="cart-item-remove" onclick="removeFromCart('${item.itemKey}')" aria-label="Eliminar">
            <span class="material-symbols-outlined">delete</span>
          </button>
        `;
        cartItems.appendChild(itemEl);
      });
    }
    
    // Update total
    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    cartTotal.textContent = `$${total.toLocaleString('es-AR')}`;
    
    // Update checkout button
    btnCheckout.disabled = cart.length === 0;
  }
  
  // Open/Close Cart
  function openCart() {
    cartSidebar.classList.add('open');
    cartBackdrop.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  
  function closeCart() {
    cartSidebar.classList.remove('open');
    cartBackdrop.classList.remove('open');
    document.body.style.overflow = '';
  }
  
  // Event Listeners
  cartFloating.addEventListener('click', openCart);
  cartClose.addEventListener('click', closeCart);
  cartBackdrop.addEventListener('click', closeCart);
  
  // Checkout - Redirect to WhatsApp
  btnCheckout.addEventListener('click', function() {
    if (cart.length === 0) return;
    
    const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    
    const itemsText = cart.map(item => {
      const emoji = '🍕';
      const subtotal = item.price * item.quantity;
      return `${emoji} ${item.name} (${item.variantLabel}) x${item.quantity} — $${subtotal.toLocaleString('es-AR')}`;
    }).join('\n');
    
    const message = `¡Hola! Quisiera hacer el siguiente pedido:\n\n${itemsText}\n\n💰 *Total: $${total.toLocaleString('es-AR')}*\n\n¿Pueden confirmarlo? ¡Gracias!`;
    
    const whatsappUrl = `https://wa.me/${business.whatsapp}?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
    
    // Optional: Clear cart after checkout
    // cart = [];
    // updateCartUI();
    // closeCart();
  });
  
  // Initialize add to cart buttons
  document.querySelectorAll('.btn-add, .btn-add-to-cart, .btn-add-variant').forEach(btn => {
    btn.addEventListener('click', function() {
      const id = this.dataset.id;
      const name = this.dataset.name;
      const price = parseInt(this.dataset.price);
      const variant = this.dataset.variant || '8-porciones';
      const variantLabel = this.dataset.variantLabel || '8 Porciones';
      
      addToCart(id, name, price, variant, variantLabel);
      
      // Show cart briefly
      openCart();
    });
  });
  
  // Initial UI state
  updateCartUI();
</script>

<style>
  /* Floating Cart Button */
  .cart-floating {
    position: fixed;
    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0rem));
    right: calc(1rem + env(safe-area-inset-right, 0rem));
    z-index: 40;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background-color: var(--color-on-surface);
    color: var(--color-surface-container-lowest);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-xl);
    transition: all 0.2s ease;
  }

  @media (min-width: 768px) {
    .cart-floating {
      bottom: 2rem;
      right: 2rem;
      width: 4rem;
      height: 4rem;
    }
  }

  .cart-floating:hover {
    background-color: var(--color-primary);
    transform: scale(1.05);
  }

  .cart-floating:active {
    transform: scale(0.95);
  }

  .cart-floating .material-symbols-outlined {
    font-size: 1.5rem;
  }

  @media (min-width: 768px) {
    .cart-floating .material-symbols-outlined {
      font-size: 1.75rem;
    }
  }

  .cart-count {
    position: absolute;
    top: -0.25rem;
    right: -0.25rem;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.25rem;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.75rem;
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-surface);
  }

  /* Cart Sidebar */
  .cart-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 24rem;
    height: 100%;
    background-color: var(--color-surface-container-lowest);
    box-shadow: var(--shadow-xl);
    z-index: 60;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .cart-sidebar.open {
    transform: translateX(0);
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .cart-header h3 {
    font-size: 1.5rem;
  }

  .cart-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-on-surface-variant);
    padding: 0.25rem;
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }

  .cart-close:hover {
    background-color: var(--color-surface-container-low);
  }

  .cart-items {
    flex-grow: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    height: 100%;
    color: var(--color-on-surface-variant);
  }

  .cart-empty .material-symbols-outlined {
    font-size: 3rem;
    opacity: 0.5;
  }

  .cart-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cart-item-image {
    width: 5rem;
    height: 5rem;
    border-radius: var(--radius-md);
    background-color: var(--color-surface-container-high);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .cart-item-image .material-symbols-outlined {
    font-size: 2rem;
    color: var(--color-on-surface-variant);
  }

  .cart-item-info {
    flex-grow: 1;
  }

  .cart-item-name {
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .cart-item-variant {
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .cart-item-price {
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
  }

  .cart-item-remove {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-on-surface-variant);
    padding: 0.5rem;
    border-radius: 50%;
    transition: all 0.2s ease;
  }

  .cart-item-remove:hover {
    background-color: var(--color-surface-container-low);
    color: var(--color-error);
  }

  .cart-footer {
    padding: 2rem;
    border-top: 1px solid var(--color-outline-variant);
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .cart-total span:first-child {
    font-size: 1.125rem;
    font-weight: 500;
  }

  .total-amount {
    font-size: 1.875rem;
    font-weight: 900;
    color: var(--color-on-surface);
  }

  .btn-checkout {
    width: 100%;
    padding: 1rem;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border: none;
    font-weight: 700;
    font-size: 1.125rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-checkout:hover:not(:disabled) {
    background-color: var(--color-primary-dim);
  }

  .btn-checkout:disabled {
    background-color: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
    cursor: not-allowed;
  }

  /* Cart Backdrop */
  .cart-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 55;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .cart-backdrop.open {
    opacity: 1;
    visibility: visible;
  }
</style>
