---
import menu from '../../menu.json';

const { categories } = menu;
const pizzas = categories.find(c => c.id === 'pizzas')?.items || [];

// Create carousel items from pizzas
const carouselItems = pizzas.map((pizza, index) => ({
  ...pizza,
  badge: index === 0 ? 'Favorito de la Casa' : null
}));
---

<section class="flavors section">
  <div class="container">
    <div class="flavors-header">
      <div class="flavors-title">
        <h2>Galería de Sabores</h2>
        <p>Cada pizza es una obra de arte creada con ingredientes de temporada y procesos lentos.</p>
      </div>
      <a href="/menu" class="flavors-link">
        Ver todo el menú
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>

    <div class="carousel-wrapper">
      <!-- Carousel Container -->
      <div class="carousel" id="flavor-carousel">
        <div class="carousel-track" id="carousel-track">
          {carouselItems.map((item, index) => (
            <div class="carousel-slide" data-index={index}>
              <div class="slide-image">
                <div class="image-placeholder">
                  <span class="material-symbols-outlined">local_pizza</span>
                </div>
              </div>
              <div class="slide-overlay">
                {item.badge && (
                  <span class="slide-badge">{item.badge}</span>
                )}
                <h3 class="slide-name">{item.name}</h3>
                <a href="/menu" class="slide-link">
                  Ver en el menú
                  <span class="material-symbols-outlined">arrow_forward</span>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button class="carousel-arrow prev" id="carousel-prev" aria-label="Anterior">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button class="carousel-arrow next" id="carousel-next" aria-label="Siguiente">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>

      <!-- Dots Indicator -->
      <div class="carousel-dots" id="carousel-dots">
        {carouselItems.map((_, index) => (
          <button 
            class="carousel-dot" 
            data-index={index}
            aria-label={`Ir a slide ${index + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Carousel Logic
  const track = document.getElementById('carousel-track');
  const slides = track?.querySelectorAll('.carousel-slide');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const dots = document.querySelectorAll('.carousel-dot');
  
  let currentIndex = 0;
  const totalSlides = slides?.length || 0;
  let autoplayInterval: ReturnType<typeof setInterval>;

  function goToSlide(index: number) {
    if (!track || !slides) return;
    
    // Wrap around
    if (index < 0) index = totalSlides - 1;
    if (index >= totalSlides) index = 0;
    
    currentIndex = index;
    
    // Move track
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    // Update dots
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentIndex);
    });
  }

  function nextSlide() {
    goToSlide(currentIndex + 1);
  }

  function prevSlide() {
    goToSlide(currentIndex - 1);
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayInterval = setInterval(nextSlide, 5000);
  }

  function stopAutoplay() {
    if (autoplayInterval) {
      clearInterval(autoplayInterval);
    }
  }

  // Event Listeners
  prevBtn?.addEventListener('click', () => {
    prevSlide();
    startAutoplay();
  });

  nextBtn?.addEventListener('click', () => {
    nextSlide();
    startAutoplay();
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || '0');
      goToSlide(index);
      startAutoplay();
    });
  });

  // Pause on hover
  const carouselWrapper = document.querySelector('.carousel-wrapper');
  carouselWrapper?.addEventListener('mouseenter', stopAutoplay);
  carouselWrapper?.addEventListener('mouseleave', startAutoplay);

  // Touch/Swipe Support
  let touchStartX = 0;
  let touchEndX = 0;

  const carousel = document.getElementById('flavor-carousel');

  carousel?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
    stopAutoplay();
  }, { passive: true });

  carousel?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
    startAutoplay();
  }, { passive: true });

  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;

    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        // Swipe left - next slide
        nextSlide();
      } else {
        // Swipe right - previous slide
        prevSlide();
      }
    }
  }

  // Initialize
  goToSlide(0);
  startAutoplay();
</script>

<style>
  .flavors {
    background-color: var(--color-surface-container-low);
    overflow: hidden;
  }

  .flavors-header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .flavors-title h2 {
    margin-bottom: 0.5rem;
  }

  .flavors-title p {
    font-size: 1.125rem;
  }

  .flavors-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .flavors-link:hover {
    text-decoration: underline;
  }

  /* Carousel Wrapper */
  .carousel-wrapper {
    position: relative;
    max-width: 520px;
    margin: 0 auto;
  }

  .carousel {
    overflow: hidden;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
  }

  .carousel-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .carousel-slide {
    flex: 0 0 100%;
    position: relative;
    aspect-ratio: 480 / 650;
  }

  .slide-image {
    position: absolute;
    inset: 0;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface-container-high) 0%, var(--color-surface-dim) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder .material-symbols-outlined {
    font-size: 8rem;
    color: var(--color-on-surface-variant);
    opacity: 0.4;
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(49, 47, 38, 0.9) 0%, rgba(49, 47, 38, 0.3) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }

  .slide-badge {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    background-color: var(--color-tertiary);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .slide-name {
    color: white;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .slide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .slide-link:hover {
    color: white;
  }

  .slide-link .material-symbols-outlined {
    font-size: 1.25rem;
    transition: transform 0.2s ease;
  }

  .slide-link:hover .material-symbols-outlined {
    transform: translateX(4px);
  }

  /* Navigation Arrows */
  .carousel-arrow {
    display: none;
  }

  .carousel-arrow .material-symbols-outlined {
    font-size: 2rem;
  }

  @media (min-width: 768px) {
    .carousel-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      background-color: var(--color-surface-container-lowest);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-lg);
      transition: all 0.2s ease;
      z-index: 10;
    }

    .carousel-arrow:hover {
      background-color: var(--color-primary);
      color: white;
    }

    .carousel-arrow.prev {
      left: -1.5rem;
    }

    .carousel-arrow.next {
      right: -1.5rem;
    }
  }

  /* Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .carousel-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background-color: var(--color-outline-variant);
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .carousel-dot.active {
    background-color: var(--color-primary);
    transform: scale(1.25);
  }

  .carousel-dot:hover:not(.active) {
    background-color: var(--color-outline);
  }

  @media (min-width: 768px) {
    .flavors-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .carousel-wrapper {
      max-width: 540px;
    }

    .carousel-arrow {
      width: 3.5rem;
      height: 3.5rem;
    }

    .carousel-arrow.prev {
      left: -2rem;
    }

    .carousel-arrow.next {
      right: -2rem;
    }
  }
</style>
