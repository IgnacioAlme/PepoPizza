---
import menu from '../../menu.json';

const { categories } = menu;
const pizzas = categories.find(c => c.id === 'pizzas')?.items || [];
---

<section class="flavors section">
  <div class="container">
    <div class="flavors-header">
      <div class="flavors-title">
        <h2>Galería de Sabores</h2>
        <p>Cada pizza es una obra de arte creada con ingredientes de temporada y procesos lentos.</p>
      </div>
      <a href="/menu" class="flavors-link">
        Ver todo el menú
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>

    <div class="flavors-grid">
      <!-- Featured Pizza (Large) -->
      <div class="flavor-card featured">
        <div class="flavor-image">
          <div class="image-placeholder featured-placeholder">
            <span class="material-symbols-outlined">local_pizza</span>
          </div>
        </div>
        <div class="flavor-overlay">
          <span class="flavor-badge">Favorito de la Casa</span>
          <h3 class="flavor-name">{pizzas[0]?.name || 'Margarita Clásica'}</h3>
          <div class="flavor-actions">
            <button class="btn-add" data-id={pizzas[0]?.id || 'muzzarella'} data-name={pizzas[0]?.name} data-price={pizzas[0]?.price}>
              Agregar
              <span class="material-symbols-outlined">add_shopping_cart</span>
            </button>
            <span class="flavor-price">${pizzas[0]?.price?.toLocaleString('es-AR') || '8.000'}</span>
          </div>
        </div>
      </div>

      <!-- Small Cards -->
      {pizzas.slice(1, 3).map((pizza) => (
        <div class="flavor-card small">
          <div class="flavor-image">
            <div class="image-placeholder">
              <span class="material-symbols-outlined">local_pizza</span>
            </div>
          </div>
          <div class="flavor-overlay">
            <h3 class="flavor-name">{pizza.name}</h3>
            <button class="btn-details">
              Detalles
              <span class="material-symbols-outlined">chevron_right</span>
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .flavors {
    background-color: var(--color-surface-container-low);
  }

  .flavors-header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .flavors-title h2 {
    margin-bottom: 0.5rem;
  }

  .flavors-title p {
    font-size: 1.125rem;
  }

  .flavors-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .flavors-link:hover {
    text-decoration: underline;
  }

  .flavors-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .flavor-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 1;
    cursor: pointer;
  }

  .flavor-card.featured {
    grid-column: 1;
    aspect-ratio: auto;
    min-height: 400px;
  }

  .flavor-image {
    position: absolute;
    inset: 0;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface-container-high) 0%, var(--color-surface-dim) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder .material-symbols-outlined {
    font-size: 4rem;
    color: var(--color-on-surface-variant);
  }

  .featured-placeholder {
    background: linear-gradient(135deg, var(--color-primary-container) 0%, var(--color-primary) 100%);
  }

  .featured-placeholder .material-symbols-outlined {
    font-size: 8rem;
    color: var(--color-on-primary);
    opacity: 0.5;
  }

  .flavor-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(49, 47, 38, 0.85) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
  }

  .flavor-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-tertiary-fixed);
    margin-bottom: 0.5rem;
  }

  .flavor-name {
    color: white;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .featured .flavor-name {
    font-size: 2.5rem;
  }

  .flavor-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .btn-add {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-add:hover {
    background-color: var(--color-primary-dim);
    transform: scale(0.98);
  }

  .btn-add .material-symbols-outlined {
    font-size: 1.25rem;
  }

  .flavor-price {
    color: white;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .btn-details {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 700;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .btn-details:hover {
    color: white;
  }

  .btn-details .material-symbols-outlined {
    font-size: 1rem;
  }

  @media (min-width: 768px) {
    .flavors-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .flavors-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: repeat(2, 280px);
      height: 900px;
    }

    .flavor-card.featured {
      grid-column: span 8;
      grid-row: span 2;
    }

    .flavor-card.small {
      grid-column: span 4;
    }

    .flavor-card.small:first-of-type {
      grid-row: 1;
    }

    .flavor-card.small:last-of-type {
      grid-row: 2;
    }
  }
</style>
